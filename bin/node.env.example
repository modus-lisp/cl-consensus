# bin/node.env.example — node-specific configuration (the CONFIG half).
#
# Copy to a private file (e.g. /etc/cl-consensus/node.env), edit, and launch the harness
# with it:   NODE_ENV=/etc/cl-consensus/node.env bin/serve-node.sh
# Everything here is a value for THIS deployment; the harness (bin/serve-node.{sh,lisp})
# stays generic.  Unset vars fall back to the defaults shown.

# --- data + logs ----------------------------------------------------------------------
export NODE_DATA=/var/lib/cl-consensus           # base dir for logs + default stores
# export SERVE_LOG=$NODE_DATA/serve-node.out
# export SUPERVISOR_LOG=$NODE_DATA/serve-node-supervisor.log
export PT_STORE=$NODE_DATA/live.pt               # UTXO store (pagetree)
export SERVE_BLOCKS=$NODE_DATA/blocks.dat        # block store
export SERVE_MEMPOOL=$NODE_DATA/mempool.dat      # persisted mempool
export BITCOIND_DATADIR=$NODE_DATA               # headers.dat (bitcoind-compatible datadir)

# --- peer to follow / archive from ----------------------------------------------------
export SERVE_PEER=127.0.0.1                       # trusted local/LAN peer (header+block source)

# --- resources ------------------------------------------------------------------------
export SBCL_HEAP_MB=16384                          # SBCL dynamic-space-size (MB)
export PT_CACHE_GB=8                                # UTXO store cache

# --- ports ----------------------------------------------------------------------------
export SERVE_PORT=8333                              # P2P listen
export RPC_PORT=8432                                # JSON-RPC (plain HTTP, no TLS)

# --- storage mode ---------------------------------------------------------------------
export ARCHIVE=0                                    # 1 = backfill ALL historical blocks (resumable)
export ARCHIVE_PEERS=16                             # fan-out for the archive backfill
# export PRUNE=288                                  # keep only last N blocks (PRUNE=1 -> 288 default); implies no archive

# --- Tor (all optional; any of these pulls the pure-CL cl-tor+seal provider) ----------
export ONION=0                                      # 1 = also dial .onion peers from the directory
export ONION_SERVICE=0                              # 1 = run our OWN v3 onion service (inbound over Tor)
# export PEER_TRANSPORT=direct                      # direct | tor (route ALL public peers over Tor) | socks5

# --- dependency discovery -------------------------------------------------------------
# Default: a :tree over the repo + its parent (finds deps/ submodules and sibling checkouts).
# Override only for a non-standard layout:
# export CL_SOURCE_REGISTRY='(:source-registry (:tree "/opt/cl-consensus") :inherit-configuration)'
